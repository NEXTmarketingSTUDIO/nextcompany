# Skopiuj do backend/.env (lokalnie). Na Renderze ustaw te same klucze w panelu Environment.

ENVIRONMENT=development

# Firebase — lokalnie plik JSON; na Renderze użyj FIREBASE_CREDENTIALS_JSON lub _B64
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=nextcompany-f0014
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# FIREBASE_CREDENTIALS_JSON_B64=...

# CEIDG (opcjonalnie)
CEIDG_API_KEY=

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/auth/hubspot/callback

# URL frontendu (Firebase Hosting) — CORS i przekierowania OAuth
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=https://twoj-projekt.web.app,https://twoj-projekt.firebaseapp.com

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=NEXTcompany

# Scheduler (UTC na Renderze)
SCRAPE_HOUR=8
SCRAPE_MINUTE=0

PORT=8000
